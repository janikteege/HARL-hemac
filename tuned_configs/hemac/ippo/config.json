{
    "algo_args": {
        "algo": {
            "action_aggregation": "prod",
            "actor_num_mini_batch": 1,
            "clip_param": 0.2,
            "critic_epoch": 5,
            "critic_num_mini_batch": 1,
            "entropy_coef": 0.01,
            "fixed_order": true,
            "gae_lambda": 0.95,
            "gamma": 0.9,
            "huber_delta": 10.0,
            "max_grad_norm": 5.0,
            "ppo_epoch": 5,
            "share_param": false,
            "use_clipped_value_loss": true,
            "use_gae": true,
            "use_huber_loss": true,
            "use_max_grad_norm": true,
