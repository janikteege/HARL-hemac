            "use_naive_recurrent_policy": false,
            "use_recurrent_policy": false,
            "weight_decay": 0
        },
        "render": {
            "render_episodes": 10,
            "use_render": false
        },
        "seed": {
            "seed": 1,
            "seed_specify": true
        },
        "train": {
            "episode_length": 600,
            "eval_interval": 25,
            "log_interval": 5,
            "model_dir": null,
            "n_rollout_threads": 20,
            "num_env_steps": 1000000,
            "use_linear_lr_decay": false,
            "use_proper_time_limits": true,
            "use_valuenorm": true
        }
    },
    "env_args": {
        "area_size": [
            1000,
            1000
        ],
